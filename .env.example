# 这是一个环境配置文件模板。
# 请将其复制并重命名为 .env，并在该文件中填写实际的配置。
# 注意：切勿在此文件中填写任何真实、敏感的密码或 API 密钥，也不要将包含真实密钥的 .env 文件提交到代码仓库。

# 数据库连接字符串 (PostgreSQL)
# 格式: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://johndoe:randompassword@localhost:5432/mydb?schema=public"

# 应用运行端口
PORT=3000

# CORS 允许的源 (可选，默认为 *，生产环境建议指定具体域名)
# CORS_ORIGIN="http://localhost:5173"

# JWT 密钥 (必须填写，用于加密 Token)
JWT_SECRET="your-secret-key-here"

# --- AI Service Configuration ---
# AI_PROVIDER 例如: "google-genai", "openai", "ollama"
AI_PROVIDER="google-genai"

# AI_MODEL_NAME 例如: "gemini-2.5-flash", "gpt-4o", "llama3"
AI_MODEL_NAME="gemini-2.5-flash"
AI_TEMPERATURE=0.7

# 通用 API Key (如果设置，将优先于特定提供商的 Key)
# AI_API_KEY="your-api-key"

# 特定提供商的 API Key (如果 AI_API_KEY 未设置)
# OPENAI_API_KEY="your-openai-api-key"
# GOOGLE_API_KEY="your-gemini-api-key"

# Ollama 本地地址
# OLLAMA_BASE_URL="http://localhost:11434"

# 文字转向量模型
# Google 示例: "gemini-embedding-001"
# Ollama 示例: "nomic-embed-text"
AI_EMBEDDING_MODEL="gemini-embedding-001"

# --- OSS Configuration ---
OSS_REGION=oss-cn-hangzhou
OSS_BUCKET=YOUR_BUCKET
OSS_ACCESS_KEY_ID=YOUR_KEY_ID
OSS_ACCESS_KEY_SECRET=YOUR_KEY_SECRET
