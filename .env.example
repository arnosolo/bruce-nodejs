# 这是一个环境配置文件模板。
# 请将其复制并重命名为 .env，并在该文件中填写实际的配置。
# 注意：切勿在此文件中填写任何真实、敏感的密码或 API 密钥，也不要将包含真实密钥的 .env 文件提交到代码仓库。

# -------------------- 安全与认证配置 --------------------
# JWT 签名密钥
JWT_SECRET="your-secret-key-here"
# 自动提升为管理员的邮箱地址
AI_CS_ADMIN_EMAIL="admin@example.com"

# -------------------- 数据库配置 PostgreSQL --------------------
DATABASE_URL="postgresql://johndoe:randompassword@localhost:5432/mydb?schema=public"

# -------------------- AI 服务配置 --------------------
# Gemini 配置
AI_PROVIDER="google-genai"
AI_MODEL_NAME="gemini-2.5-flash"
GOOGLE_API_KEY="" # https://aistudio.google.com/api-keys
AI_TEMPERATURE=0.7
AI_EMBEDDING_MODEL="gemini-embedding-001"

# 千问配置
# AI_PROVIDER="qwen"
# AI_MODEL_NAME="qwen-plus"
# QWEN_API_KEY="" # https://dashscope.console.aliyun.com/
# AI_EMBEDDING_MODEL="text-embedding-v3"

# Ollama 配置
# OLLAMA_BASE_URL="http://localhost:11434"
# AI_PROVIDER="ollama"
# AI_MODEL_NAME="qwen3.5:9b"
# AI_TEMPERATURE=0.7
# AI_EMBEDDING_MODEL="nomic-embed-text:v1.5"

# -------------------- 对象存储 OSS 配置 --------------------
OSS_REGION=oss-cn-hangzhou
OSS_BUCKET=YOUR_BUCKET
OSS_ACCESS_KEY_ID=YOUR_KEY_ID
OSS_ACCESS_KEY_SECRET=YOUR_KEY_SECRET

# -------------------- 应用基础配置 --------------------
# 应用运行端口
PORT=3000

# CORS 允许的源 (可选，默认为 *，生产环境建议指定具体域名)
# CORS_ORIGIN="http://localhost:5173"
