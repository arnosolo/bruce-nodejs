// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model Faq {
  id             Int                     @id @default(autoincrement())
  question       String                  @db.Text
  answer         String                  @db.Text
  embedding      Unsupported("vector(768)")?
  embeddingModel String?                 @db.VarChar(255)
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
}

enum Role {
  CUSTOMER
  AGENT
  AI
  ADMIN
}

model User {
  id                       Int            @id @default(autoincrement())
  email                    String         @unique
  password                 String?
  name                     String?
  avatarKey                String?        @db.VarChar(512)
  role                     Role           @default(CUSTOMER)
  isEmailVerified          Boolean        @default(false)
  emailVerificationCode    String?        @db.VarChar(10)
  emailVerificationExpires DateTime?
  loginCode                String?        @db.VarChar(10)
  loginCodeExpires         DateTime?
  deletedAt                DateTime?
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt
  conversations            Conversation[]
  messages                 Message[]
}

model Conversation {
  id               Int       @id @default(autoincrement())
  title            String?   @db.VarChar(255)
  isTitleGenerated Boolean   @default(false)
  userId           Int
  user             User      @relation(fields: [userId], references: [id])
  messages         Message[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  // 为 userId 添加索引，大幅提升根据用户查询会话列表的性能
  @@index([userId])
}

model Message {
  id             Int          @id @default(autoincrement())
  content        String       @db.Text
  role           MessageRole
  type           MessageType  @default(TEXT)
  attachmentKey  String?      @db.VarChar(512)
  senderId       Int?         // 逻辑关联发送者ID (User.id)，AI消息可为空
  sender         User?        @relation(fields: [senderId], references: [id])
  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  createdAt      DateTime     @default(now())

  // 为 conversationId 和 senderId 添加索引，提升查询性能
  @@index([conversationId])
  @@index([senderId])
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum MessageType {
  TEXT
  IMAGE
  FILE
}
